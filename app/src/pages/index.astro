&#125;);

<span class="token-keyword">const</span> data = <span class="token-keyword">await</span> response.<span class="token-function">json</span>();
<span class="token-keyword">const</span> latest = data.items
  .<span class="token-function">slice</span>()
  .<span class="token-function">sort</span>((a, b) =>
